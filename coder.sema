#!/usr/bin/env sema
;; ── Sema Coder — a terminal coding agent written in Sema ──
;;
;; Entry point: parse args, load config, build the agent, hand off to the
;; TUI (on a TTY), one-shot mode (-p), or the plain line REPL (piped stdin).
;; The modules live in src/ (load resolves relative to this file).
;;
;;   ./coder.sema                 ;; interactive (chmod +x, or: sema coder.sema)
;;   ./coder.sema -- -p "..."     ;; one-shot
;;   ./coder.sema -- -m <model>   ;; override model

(load "src/cli.sema")
(load "src/banner.sema")
(load "src/tui.sema")   ;; brings in commands, agent, tools, mcp, session, …

(define VERSION "0.2.0")

(try
  (begin
    (define cli (parse-cli))
    (when (:help cli) (show-usage) (exit 0))
    (when (:version cli) (println (format "sema-coder ~a" VERSION)) (exit 0))

    (define provider (llm/auto-configure))
    (when (nil? provider)
      (io/println-error "Error: No API key found. Set ANTHROPIC_API_KEY or OPENAI_API_KEY.")
      (exit 1))

    (define cfg   (boot-config!))    ;; ensure + load init.sema, reconcile commands + servers
    (define cwd   (sys/cwd))
    (define model (:model cli))
    (mcp-autostart!)                 ;; connect :autostart servers before the agent is built
    ;; not `agent` — that name would shadow the (agent {…}) builtin constructor.
    (define sema-coder-agent (create-agent cwd model cfg))

    ;; One-shot mode — prose to stdout, nothing else.
    (when (:prompt cli)
      (let ((result (run-turn sema-coder-agent (:prompt cli) '() on-tool-call)))
        (println (:response result))
        (exit 0)))

    ;; Interactive, on a TTY → the full-screen TUI.
    (when (sys/tty)
      (tui-run cwd model cfg sema-coder-agent)
      (exit 0))

    ;; Not a TTY (piped/dumb terminal) → the plain line-based REPL below.
    (show-banner VERSION)
    (show-welcome cwd model)
    (let ((na (mcp-needs-auth)))
      (unless (null? na)
        (show-info (format "~a MCP server(s) need auth: ~a" (length na) (string/join na ", ")))))

    (define state
      {:messages '() :model model :cwd cwd :agent sema-coder-agent :config cfg})

    (defun handle-input (input)
      (cond
        ((nil? input)                       ;; EOF — stdin closed
          (io/println-error "")
          (show-info "bye")
          (exit 0))
        ((= (string/trim input) "") nil)    ;; blank line — ignore
        ((slash-command? input)
          (let ((next (try
                        (dispatch-command (parse-command input) state)
                        (catch e
                          (show-error (format "command failed: ~a" (get e :message (str e))))
                          state))))
            (if (equal? next 'quit)
              (begin (show-info "bye") (exit 0))
              (set! state next))))
        (else
          (let ((result (try
                          (run-turn (:agent state) (string/trim input) (:messages state) on-tool-call)
                          (catch e
                            (show-error (format "agent error: ~a" (get e :message (str e))))
                            #f))))
            (when result
              (show-response (:response result))
              (set! state (assoc state :messages (:messages result))))))))

    (let loop ()
      (show-prompt)
      (handle-input (io/read-line))
      (loop)))

  (catch e
    (io/println-error (format "Fatal error: ~a" (get e :message (str e))))
    (exit 1)))
