;; commands.sema — slash-command registry + built-ins
;;
;; Adding a command is one call:
;;
;;   (register-command! "name" "what it does"
;;     (lambda (state args) ... return state (or 'quit)))
;;
;; A handler receives the live REPL state map and the argument string (text
;; after the command name) and returns the next state. Handlers write output
;; through `emit` (see display.sema), so the same registry drives the plain
;; REPL and the full-screen TUI — the TUI just parameterizes the sink.
;;
;; Users can ALSO define commands declaratively in init.sema without touching
;; this file — see the `:commands` list of (command name spec) records below.

(load "util.sema")     ;; sh-quote (open-config!)
(load "display.sema")
(load "config.sema")
(load "agent.sema")
(load "session.sema")
(load "keymap.sema")   ;; command records may declare a :key

;; ── Registry ─────────────────────────────────────────────────────

(define *commands* {})        ;; name(string) → {:desc :handler}
(define *command-order* '())  ;; registration order, for /help
(define *tui-active* #f)      ;; set by tui-run; gates modal-vs-print behaviour

(defun register-command! (name desc handler)
  (set! *commands* (assoc *commands* name {:desc desc :handler handler}))
  (unless (member name *command-order*)
    (set! *command-order* (append *command-order* (list name)))))

;; ── Argument completions ─────────────────────────────────────────
;; A command may register a completion source for its argument. The TUI palette
;; fuzzy-filters these once the input reads "/cmd <partial>"; commands without
;; a source keep the plain prompt.

(define *command-completions* {})  ;; name(string) → (fn state → ({:value :label [:active]} …))

(defun register-completions! (name f)
  (set! *command-completions* (assoc *command-completions* name f)))

(defun command-has-completions? (name)
  (if (get *command-completions* name #f) #t #f))

(defun command-completions (name state)
  "Completion entries for /NAME's argument — ({:value … :label …} …), or '().
   :value is what gets inserted/run; :label is the human line shown; an entry
   with :active #t marks the currently-in-effect value (rendered as ●)."
  ;; nil default (not #f): on current sema `if-let` treats #f as truthy and
  ;; would call (f state) on a missing entry.
  (if-let (f (get *command-completions* name nil))
    (f state)
    '()))

(defun slash-command? (input)
  (string/starts-with? (string/trim input) "/"))

(defun parse-command (input)
  "\"/model gpt-x\" → {:name \"model\" :args \"gpt-x\"}"
  (let* ((trimmed (string/trim input))
         (sp      (string/index-of trimmed " ")))
    (if sp
      {:name (string/slice trimmed 1 sp)
       :args (string/trim (string/slice trimmed sp (string/length trimmed)))}
      {:name (string/slice trimmed 1 (string/length trimmed)) :args ""})))

(defun dispatch-command (cmd state)
  ;; Config-declared commands are registered into *commands* by reconcile, so the
  ;; one registry answers everything.
  (if-let (spec (get *commands* (:name cmd) nil))
    ((:handler spec) state (:args cmd))
    (begin
      (emit :error f"unknown command: /${(:name cmd)} (try /help)")
      state)))

(defun run-user-command (template args)
  "Run a config-defined command: substitute $ARGS, run in the workspace."
  (let* ((cmd    (string/replace template "$ARGS" args))
         (result (run-in-workspace cmd))
         (out    (string/trim (:stdout result)))
         (err    (string/trim (:stderr result))))
    (emit :info (string/append "$ " cmd))
    (unless (= out "") (emit :raw out))
    (unless (= err "") (emit :error err))))

;; ── Config-declared commands (data forms; argv by default, no shell) ──
;; A command record from (command name spec) carries :desc and one of :run
;; (argv vector) / :do (fn state args) / :shell (template). Config owns a
;; replaceable set, so a reload drops removed ones — no accumulation.

(define *config-command-names* '())
(defun config-command-names () *config-command-names*)

(defun argv-for (argv args)
  "Build the argv LIST from ARGV (vector), splicing the typed ARGS string as ONE
   argument where :args appears (dropped if empty); if :args is absent, append
   ARGS when non-empty. Never interpreted by a shell."
  (let ((lst (if (vector? argv) (vector->list argv) argv)))
    (if (member :args lst)
      (apply append
        (map (lambda (x) (cond ((equal? x :args) (if (= args "") '() (list args)))
                               (else (list x))))
             lst))
      (if (= args "") lst (append lst (list args))))))

(defun run-argv-command (argv args)
  ;; sh-quote every token so the argv list runs in the workspace just like the
  ;; :shell variant — `run-in-workspace` pins cwd via `cd <root> &&`.
  (let* ((full (argv-for argv args))
         (res  (run-in-workspace (string/join (map sh-quote full) " ")))
         (out  (string/trim (:stdout res)))
         (err  (string/trim (:stderr res))))
    (emit :info (string/append "$ " (string/join full " ")))
    (unless (= out "") (emit :raw out))
    (unless (= err "") (emit :error err))))

(defun config-command-handler (spec)
  "Turn a command record into a (state args) → state handler."
  (lambda (state args)
    (cond
      ((:do spec)    ((:do spec) state args))
      ((:run spec)   (run-argv-command (:run spec) args) state)
      ((:shell spec) (run-user-command (:shell spec) args) state)
      (else (emit :error f"command /${(:name spec)} has no :run, :do, or :shell")
            state))))

(defun unregister-command! (name)
  (set! *commands* (dissoc *commands* name))
  (set! *command-order* (filter #(not (= % name)) *command-order*)))

(defun reconcile-commands! (cmds)
  "Replace the config-owned command set with CMDS (list of command records).
   A record's :key becomes a keybinding for the like-named action, replaced
   wholesale each reconcile so a removed :key unbinds."
  (for-each unregister-command! *config-command-names*)
  (set! *config-command-names* (map :name cmds))
  (for-each
    (lambda (spec)
      (register-command! (:name spec) (get spec :desc "") (config-command-handler spec)))
    cmds)
  (set-command-keys!
    (foldl (lambda (m spec)
             (let ((k (get spec :key #f)))
               (if k (assoc m (string->keyword (:name spec)) k) m)))
           {} cmds)))

(defun boot-config! ()
  "Ensure init.sema exists, load it, reconcile config-owned commands; return the
   config value (defaults + an emitted error on a broken file)."
  (ensure-config!)
  (let* ((r   (load-config (config-path)))
         (cfg (if (:ok r) (:ok r)
                (begin (emit :error f"config: ${(:error r)} — using defaults")
                       default-config))))
    (reconcile-commands! (:commands cfg))
    (reconcile-servers! (:mcp-servers cfg))
    cfg))

(defun editor-command ()
  "The user's preferred editor: $VISUAL, then $EDITOR (may carry flags), or nil."
  ;; nil (not #f) when unset: open-config! uses when-let, which treats #f as
  ;; truthy on current sema and would run a shell command literally named "#f".
  (let ((v (env "VISUAL")) (e (env "EDITOR")))
    (cond ((and v (not (= v ""))) v)
          ((and e (not (= e ""))) e)
          (else nil))))

(defun opened-ok? (res) (= (get res :exit-code 1) 0))

(defun open-config! ()
  "Open init.sema in the user's editor. $VISUAL/$EDITOR first (zed, code, subl
   — their CLIs detach; stdin is closed so a purely terminal editor, which
   can't take over the TUI's tty, fails fast instead of wedging the app), then
   the platform opener. macOS needs `open -t` because nothing claims the .sema
   extension. Returns #t if an opener reported success."
  (let ((path (config-path)))
    (or
      (when-let (ed (editor-command))
        (opened-ok?
          (try (shell "sh" "-c" f"${ed} ${(sh-quote path)} </dev/null")
            (catch e {:exit-code 1}))))
      (opened-ok?
        (try
          (match (sys/platform)
            ("macos"   (shell "open" "-t" path))
            ("windows" (shell "cmd" "/c" "start" "" path))
            (_         (shell "xdg-open" path)))
          (catch e {:exit-code 1}))))))

;; ── Built-in commands ────────────────────────────────────────────

(defun help-row (name desc)
  (format "    ~a  ~a"
    (accent (string/pad-right (string/append "/" name) 16))
    (muted desc)))

(register-command! "help" "Show this help"
  (lambda (state args)
    (emit :line "")
    (emit :line (heading "  Commands"))
    (for-each
      (lambda (name)
        (emit :line (help-row name (get (get *commands* name {}) :desc ""))))
      *command-order*)
    (emit :line "")
    state))

(defun provider-env-key (name)
  "The conventional API-key env var for a provider display NAME, or #f."
  (match (string/lower name)
    ("anthropic" "ANTHROPIC_API_KEY")
    ("openai"    "OPENAI_API_KEY")
    (_ #f)))

(defun provider-key-missing? (name)
  "True when NAME's key env var is known and unset — its models can't be called."
  ;; plain let/if: provider-env-key returns #f for unknown providers, which
  ;; current sema's `if-let` would wrongly treat as truthy (then (env #f)).
  (let ((k (provider-env-key name)))
    (if k (let ((v (env k))) (if (or (nil? v) (= v "")) #t #f)) #f)))

(register-command! "model" "Show or switch the model: /model [name]"
  (lambda (state args)
    (let* ((cfg     (get state :config {}))
           (current (choose-model (get state :model "") cfg)))
      (if (= args "")
        (begin
          (emit :info f"model: ${(if (= current "") "auto" current)}")
          (for-each
            (lambda (m) (emit :line (format "    ~a  ~a~a"
                                      (accent (string/pad-right (:id m) 22))
                                      (muted f"${(:provider m)}: ${(:label m)}")
                                      (string/append
                                        (if (= (:id m) current) (ok " ●") "")
                                        (if (provider-key-missing? (:provider m)) (muted " · no key") "")))))
            (model-entries cfg))
          state)
        (let ((entry (model-entry cfg args)))
          (emit :ok (if entry
                      f"switched to ${args} (${(:provider entry)})"
                      f"switched to ${args}"))
          (when (and entry (provider-key-missing? (:provider entry)))
            (emit :info f"note: ${(provider-env-key (:provider entry))} is not set — requests to this model will fail"))
          (when (and entry (not (= (get entry :effort "") "")) (= (get state :effort "") ""))
            (emit :info f"effort → ${(get entry :effort "")} (model default; /effort overrides)"))
          (assoc state
            :model args
            :agent (create-agent (:cwd state) args cfg)))))))

;; The /model argument completes from the config's :models provider groups
;; (see config.sema) — shown in the palette as "Provider: Model Name", with the
;; active model marked and providers whose API key is missing annotated.
(register-completions! "model"
  (lambda (state)
    (let* ((cfg     (get state :config {}))
           (current (choose-model (get state :model "") cfg)))
      (map (lambda (m)
             {:value  (:id m)
              :label  (string/append f"${(:provider m)}: ${(:label m)}"
                                     (if (provider-key-missing? (:provider m)) " · no key" ""))
              :active (= (:id m) current)})
           (model-entries cfg)))))

;; Sema's portable :reasoning-effort levels (llm docs); models without
;; reasoning support ignore the option, so no per-model gating is needed.
(define effort-levels (list "none" "minimal" "low" "medium" "high" "xhigh"))

(register-command! "effort" "Show or set reasoning effort: /effort [level|default]"
  (lambda (state args)
    ;; Accept ":high" as well as "high" — the docs write levels as keywords.
    (let ((v (let ((a (string/trim args)))
               (if (string/starts-with? a ":") (string/slice a 1 (string/length a)) a))))
      (cond
        ((= v "")
          (let* ((cfg (get state :config {}))
                 (cur (pick-effort (get state :effort "") (choose-model (get state :model "") cfg) cfg)))
            (emit :info f"effort: ${(if (= cur "") "default" cur)} · levels: ${(string/join effort-levels ", ")} · /effort default resets"))
          state)
        ((= v "default")
          (emit :ok "reasoning effort → provider default")
          (assoc state :effort ""))
        ((member v effort-levels)
          (emit :ok f"reasoning effort → ${v}")
          ;; Honest heads-up: on chat/completions, some OpenAI models reject a
          ;; non-none effort together with tools (gpt-5.6+). The runtime degrades
          ;; gracefully (auto-retries at default) rather than failing the turn —
          ;; but say so, since the effort you set may not actually apply there.
          (let* ((cfg (get state :config {}))
                 (mid (choose-model (get state :model "") cfg)))
            (when (and (not (= v "none")) (= (model-provider-name cfg mid) "openai"))
              (emit :info "note: some OpenAI models apply effort at their default when tools are used — the runtime auto-handles this (no turn fails)")))
          (assoc state :effort v))
        (else
          (emit :error f"unknown effort “${v}” (try ${(string/join effort-levels ", ")}, or default)")
          state)))))

(register-completions! "effort"
  (lambda (state)
    (let* ((cfg (get state :config {}))
           (cur (pick-effort (get state :effort "") (choose-model (get state :model "") cfg) cfg))
           (mark (if (= cur "") "default" cur)))
      (map (lambda (e) (assoc e :active (= (:value e) mark)))
        (list {:value "none"    :label "none — thinking disabled"}
              {:value "minimal" :label "minimal — barely deliberates"}
              {:value "low"     :label "low — quick and cheap"}
              {:value "medium"  :label "medium — balanced"}
              {:value "high"    :label "high — thorough"}
              {:value "xhigh"   :label "xhigh — maximum deliberation"}
              {:value "default" :label "default — back to the provider default"})))))

(register-command! "clear" "Clear the conversation history"
  (lambda (state args)
    (emit :clear "")
    (emit :info "conversation cleared")
    (assoc state :messages '())))

(register-command! "tools" "List the agent's tools"
  (lambda (state args)
    (let ((origins (mcp-tool-origins)))
      (for-each
        (lambda (t)
          (let ((srv (get origins (tool/name t) #f)))
            (emit :line (string/append "    " (accent (string/pad-right (tool/name t) 14))
                                       (if srv (muted f"· mcp:${srv}") "")))))
        (agent-tools)))
    state))

(register-command! "mcp" "Manage MCP servers (opens the modal; ⌃O in the TUI)"
  (lambda (state args)
    (if *tui-active*
      (open-mcp-modal!)
      (let ((servers (mcp-records)))
        (if (= (length servers) 0)
          (emit :info "no MCP servers declared (add one in init.sema)")
          (for-each
            (lambda (r) (emit :line (format "    ~a  ~a  ~a"
                                     (string/pad-right (:name r) 14)
                                     (string/pad-right (:transport r) 6)
                                     (:status r))))
            servers))))
    state))

(register-command! "resume" "Resume a past session: /resume [id] (modal: ⌃R in the TUI)"
  (lambda (state args)
    (cond
      ;; /resume <id> — restore directly, no modal.
      ((not (= args ""))
        (if *tui-active*
          (begin
            (try (restore-session! args)
              (catch e (emit :error f"couldn't restore “${args}”: ${(get e :message (str e))}")))
            ;; restore-session! updates the TUI globals; hand them back as state.
            (tui-state))
          (let ((r (try (load-session args) (catch e #f))))
            (if (not r)
              (begin (emit :error f"no session “${args}” (try /resume for the list)") state)
              (let* ((meta (:meta r))
                     (m    (get meta :model "")))
                (emit :ok f"resumed “${(get meta :title args)}” · ${(length (:messages r))} messages")
                (assoc state
                  :messages (:messages r)
                  :model  m
                  :effort (get meta :effort "")
                  :agent  (create-agent (:cwd state) m (get state :config {}))))))))
      (*tui-active* (open-resume-modal!) state)
      (else
        (let ((ss (list-sessions)))
          (if (= (length ss) 0)
            (emit :info "no saved sessions yet")
            (for-each
              (lambda (m) (emit :line (format "    ~a  ~a msgs  ~a"
                                       (string/pad-right (:title m) 40) (:count m) (:id m))))
              ss)))
        state))))

;; The /resume argument completes from the saved sessions, newest first.
(register-completions! "resume"
  (lambda (state)
    (map (lambda (m) {:value (:id m)
                      :label f"${(:title m)} · ${(:count m)} msgs"})
         (list-sessions))))

(register-command! "cwd" "Show the working directory"
  (lambda (state args) (emit :info (:cwd state)) state))

(register-completions! "config"
  (lambda (state)
    (list {:value "edit" :label "open init.sema in your editor"})))

(register-command! "config" "Show the config path (/config edit opens it)"
  (lambda (state args)
    (if (= args "edit")
      (if (open-config!)
        (emit :info f"opening ${(config-path)}")
        (emit :error f"couldn't open an editor — edit ${(config-path)} manually"))
      (begin
        (emit :info f"config: ${(config-path)}")
        (emit :info "edit it in any pane — changes hot-reload on save")))
    state))

(register-command! "reload" "Reload config from disk and rebuild the agent"
  (lambda (state args)
    ;; On a broken init.sema, keep the running config (like the file-watch
    ;; reload) instead of reconciling to defaults — a typo must not wipe the
    ;; user's live commands, keybindings, and MCP servers.
    (let ((r (load-config (config-path))))
      (if (:ok r)
        (let ((cfg (:ok r)))
          (reconcile-commands! (:commands cfg))
          (reconcile-servers! (:mcp-servers cfg))
          (mcp-autostart!)
          (emit :ok "config reloaded")
          (assoc state
            :config cfg
            :agent (create-agent (:cwd state) (:model state) cfg)))
        (begin
          (emit :error f"config: ${(:error r)} — keeping current config")
          state)))))

(register-command! "quit" "Exit Sema Coder" (lambda (state args) 'quit))
(register-command! "exit" "Exit Sema Coder" (lambda (state args) 'quit))
