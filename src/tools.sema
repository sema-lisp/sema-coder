;; tools.sema — LLM-callable tools for the Sema Coder agent
;;
;; Seven tools: read-file, write-file, edit-file, bash, grep, find-files,
;; list-dir. Every path funnels through resolve-path / resolve-dir, which keep
;; reads, writes, and searches inside the workspace root (see util.sema). The
;; search tools invoke their programs argv-style — no `sh -c` — so a pattern
;; or path can't smuggle shell syntax into the command line.

(load "util.sema")
(load "text.sema")

(define MAX-READ-LINES   2000)   ;; read-file cap
(define MAX-OUTPUT-LINES 500)    ;; bash output cap
(define MAX-MATCH-LINES  100)    ;; grep result cap
(define MAX-FIND-LINES   200)    ;; find-files result cap

(deftool read-file
  "Read a file and return its contents with line numbers. Always read a file before editing it. Truncates very large files."
  {:path {:type :string :description "Path to the file to read (relative to the workspace)"}}
  (lambda (path)
    (try
      (let ((resolved (resolve-path workspace-root path)))
        (if (file/exists? resolved)
          (-> (file/read resolved)
              lines->numbered
              (truncate-lines MAX-READ-LINES))
          (format "Error: File not found: ~a" path)))
      (catch e (format "Error reading file ~a: ~a" path e)))))

(deftool write-file
  "Create or overwrite a file. Creates parent directories automatically."
  {:path    {:type :string :description "Path to write (relative to the workspace)"}
   :content {:type :string :description "Content to write"}}
  (lambda (path content)
    (try
      (let ((resolved (resolve-path workspace-root path)))
        (file/mkdir (path/dir resolved))
        (file/write resolved content)
        (format "Wrote ~a chars to ~a" (string/length content) path))
      (catch e (format "Error writing file ~a: ~a" path e)))))

(defun count-occurrences (haystack needle)
  "How many times NEEDLE appears in HAYSTACK (n matches → n+1 split parts)."
  (- (length (string/split haystack needle)) 1))

(deftool edit-file
  "Edit a file by replacing an exact string match. You MUST read the file first. old_string must match exactly (including whitespace) and appear exactly once."
  {:path       {:type :string :description "Path to edit (relative to the workspace)"}
   :old_string {:type :string :description "Exact string to find"}
   :new_string {:type :string :description "Replacement string"}}
  (lambda (path old_string new_string)
    (try
      (let ((resolved (resolve-path workspace-root path)))
        (if (not (file/exists? resolved))
          (format "Error: File not found: ~a" path)
          (let* ((content (file/read resolved))
                 (n       (count-occurrences content old_string)))
            (cond
              ((= n 0)
                (format "Error: old_string not found in ~a. Read the file first." path))
              ((> n 1)
                (format "Error: old_string matches ~a times in ~a. Add surrounding context to make it unique." n path))
              (else
                (file/write resolved (string/replace content old_string new_string))
                (format "Edited ~a (1 replacement)" path))))))
      (catch e (format "Error editing file ~a: ~a" path e)))))

;; ── Shell-backed tools ───────────────────────────────────────────

(defun run-in-workspace (command)
  "Run a shell command with cwd pinned to the workspace root."
  (shell "sh" "-c" (string/append "cd " (sh-quote workspace-root) " && " command)))

(deftool bash
  "Run a shell command in the workspace. Returns stdout, stderr, and exit code. Use for tests, builds, git — not for reading/searching files (use read-file/grep)."
  {:command {:type :string :description "The shell command to run"}}
  (lambda (command)
    (try
      (let* ((result (run-in-workspace command))
             (out    (:stdout result))
             (err    (:stderr result))
             (code   (:exit-code result))
             (parts  (append
                       (if (= (string/trim out) "") '() (list out))
                       (if (= (string/trim err) "") '() (list (format "stderr:\n~a" err)))
                       (if (= code 0) '() (list (format "Exit code: ~a" code))))))
        (if (null? parts)
          "Command completed successfully (no output)."
          (-> (string/join parts "\n") (truncate-lines MAX-OUTPUT-LINES))))
      (catch e (format "Error running command: ~a" e)))))

(defun search-workspace (pattern target)
  "ripgrep when available, else grep -rn. Both invoked argv-style; `--` keeps
   a pattern starting with `-` from being read as a flag."
  (try (shell "rg" "--line-number" "--max-count" "10" "--no-heading" "--" pattern target)
       (catch e (shell "grep" "-rn" "-m" "10" "--" pattern target))))

(deftool grep
  "Search file contents for a pattern (regex). Returns matching lines with paths and line numbers. Prefers ripgrep, falls back to grep."
  {:pattern {:type :string :description "Search pattern (text or regex)"}
   :path    {:type :string :description "Directory or file to search (default: workspace root)"}}
  (lambda (pattern path)
    (if (or (nil? pattern) (= pattern ""))
      "Error: pattern is required"
      (try
        (let* ((result (search-workspace pattern (resolve-dir workspace-root path)))
               (out    (string/trim (:stdout result)))
               (err    (string/trim (:stderr result))))
          (cond
            ((not (= out "")) (truncate-lines out MAX-MATCH-LINES))
            ((= err "")       "No matches found.")
            (else             (format "Error searching: ~a" err))))
        (catch e (format "Error searching: ~a" e))))))

(deftool find-files
  "Find files by glob pattern. Skips .git, node_modules, target."
  {:pattern {:type :string :description "Glob (e.g. '*.rs', 'Cargo.toml')"}
   :path    {:type :string :description "Directory to search (default: workspace root)"}}
  (lambda (pattern path)
    (if (or (nil? pattern) (= pattern ""))
      "Error: pattern is required"
      (try
        (let* ((result (shell "find" (resolve-dir workspace-root path) "-name" pattern
                              "-not" "-path" "*/.git/*"
                              "-not" "-path" "*/node_modules/*"
                              "-not" "-path" "*/target/*"))
               (out    (string/trim (:stdout result))))
          (if (= out "") "No files found." (truncate-lines out MAX-FIND-LINES)))
        (catch e (format "Error finding files: ~a" e))))))

(deftool list-dir
  "List directory contents with types and sizes."
  {:path {:type :string :description "Directory to list (default: workspace root)"}}
  (lambda (path)
    (try
      (let* ((result (shell "ls" "-la" (resolve-dir workspace-root path)))
             (out    (string/trim (:stdout result)))
             (err    (string/trim (:stderr result))))
        (cond
          ((not (= out "")) out)
          ((= err "")       (format "Error: Directory empty or not found: ~a" path))
          (else             (format "Error listing directory ~a: ~a" path err))))
      (catch e (format "Error listing directory ~a: ~a" path e)))))

(defun all-tools ()
  (list read-file write-file edit-file bash grep find-files list-dir))

;; Derived from the tools themselves — no hand-synced list to drift.
(defun tool-names () (map tool/name (all-tools)))
