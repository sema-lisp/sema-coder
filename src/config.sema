;; config.sema — configuration as DATA.
;;
;; init.sema is Lisp that calls value-returning constructors (coder-config,
;; mcp-server, command, provider, model) and hands the result to
;; (configure! cfg). The loader is
;; pure: it captures that value and returns {:ok cfg} | {:error e} — it never
;; mutates the app's active config or prints, so the caller owns recovery policy
;; and reconciles runtime to the returned value (no accumulators, no reset).

;; A parameter so tests (and a future --config flag) can redirect the dir.
(define config-dir-override (make-parameter #f))
(defun config-dir ()
  (or (config-dir-override)
      (let ((e (env "SEMA_CODER_CONFIG_DIR"))) (if (and e (not (= e ""))) e #f))
      (path/join (sys/config-dir) "sema" "sema-coder")))
(defun config-path () (path/join (config-dir) "init.sema"))

;; ── Constructors: return values, never mutate ────────────────────

(defun model (id label . opts)
  "A selectable model: ID is what the provider API accepts, LABEL is the human
   name shown by the /model autocomplete. An optional OPTS map carries
   per-model defaults — currently :effort, applied unless /effort overrides."
  (merge (if (null? opts) {} (car opts)) {:id id :label label}))

(defun provider (name models)
  "A provider group for the /model autocomplete: display NAME plus its MODELS
   (a list of (model …) records)."
  {:name name :models models})

;; The providers/models offered by the /model autocomplete. Purely a picker
;; list — any model id typed by hand still works. A config's own :models
;; replaces this wholesale.
(define default-models
  (list
    (provider "Anthropic"
      (list
        (model "claude-opus-4-6"  "Claude Opus 4.6")
        (model "claude-sonnet-5"  "Claude Sonnet 5")
        (model "claude-haiku-4-5" "Claude Haiku 4.5")))
    (provider "OpenAI"
      (list
        (model "gpt-5.6-sol"   "GPT-5.6 Sol")
        (model "gpt-5.6-terra" "GPT-5.6 Terra")
        (model "gpt-5.6-luna"  "GPT-5.6 Luna")
        (model "gpt-5.5"       "GPT-5.5")))))

(define default-config
  {:model              ""        ;; "" = auto-detect from API keys
   :effort             ""        ;; reasoning effort; "" = provider default (see /effort)
   :max-turns          50
   :tool-preview-lines 5         ;; result lines shown under a tool call in the TUI
   :models             default-models
   :mcp-servers        '()
   :commands           '()
   :keys               {}})      ;; action → key overrides (e.g. {:mcp "ctrl-p"})

(defun model-entries (cfg)
  "Flatten the config's :models provider groups into {:id :label :provider}
   entries, in declaration order."
  (apply append
    (map (lambda (p)
           (map (lambda (m) (assoc m :provider (:name p))) (get p :models '())))
         (get cfg :models '()))))

(defun model-entry (cfg model-id)
  "The :models entry whose :id is MODEL-ID, or #f."
  (let ((hits (filter #(= (:id %) model-id) (model-entries cfg))))
    (if (null? hits) #f (car hits))))

(defun model-effort (cfg model-id)
  "The per-model :effort default declared on CFG's entry for MODEL-ID, or \"\"."
  ;; plain `let`/`if`, not `if-let`: model-entry returns #f when absent, and on
  ;; current sema `if-let` treats #f as truthy — it would bind e=#f and crash in
  ;; `get`. `if` reads #f as falsy correctly.
  (let ((e (model-entry cfg model-id)))
    (if e (get e :effort "") "")))

(defun mcp-server (name opts)
  "A server record. OPTS is the mcp/connect map plus the app key :autostart."
  {:name      name
   :opts      (dissoc opts :autostart)
   :autostart (get opts :autostart #f)
   :transport (if (get opts :url #f) "http" "stdio")})

(defun command (name spec)
  "A command record. SPEC carries :desc and one of :run (argv) / :do (fn) /
   :shell, plus an optional :key (e.g. \"ctrl-t\") that binds the command to a
   keyboard shortcut."
  (assoc spec :name name))

(defun coder-config (m)
  "Assemble the config value, filling any omitted key from the defaults."
  (merge default-config m))

;; ── Single sink + pure loader ────────────────────────────────────
;; configure! writes a scratch cell, not the active config, so a load that
;; throws mid-file can't leave the app's config half-applied.

(define *pending-config* #f)

(defun configure! (cfg) (set! *pending-config* cfg) cfg)

(defun load-config (path)
  "Read + evaluate PATH, capture the configured value. Pure: {:ok cfg} | {:error e}."
  (set! *pending-config* #f)
  (try
    (begin
      (load path)
      (if *pending-config*
        {:ok *pending-config*}
        {:error "init.sema did not call (configure! …)"}))
    (catch e {:error e})))

;; ── First-run default (annotated so humans + agents copy correct syntax) ──

(define default-init-source
";; init.sema — Sema Coder config (Lisp data, hot-reloaded on save).
;; Edit in any editor; declarations are values the app reconciles to.

(configure!
  (coder-config
    {:model      \"\"                 ; \"\" = auto-detect from API keys; or \"claude-sonnet-5\"
     :effort     \"\"                 ; none/minimal/low/medium/high/xhigh; \"\" = provider default
     :max-turns  50
     :tool-preview-lines 5          ; result lines shown under each tool call

     ;; ── Models offered by the /model autocomplete, grouped by provider. ──
     ;; Only a picker list — any model id typed by hand still works. A model
     ;; may carry per-model defaults, e.g.
     ;;   (model \"gpt-5.6-sol\" \"GPT-5.6 Sol\" {:effort \"high\"})
     :models
     (list
       (provider \"Anthropic\"
         (list
           (model \"claude-opus-4-6\"  \"Claude Opus 4.6\")
           (model \"claude-sonnet-5\"  \"Claude Sonnet 5\")
           (model \"claude-haiku-4-5\" \"Claude Haiku 4.5\")))
       (provider \"OpenAI\"
         (list
           (model \"gpt-5.6-sol\"   \"GPT-5.6 Sol\")
           (model \"gpt-5.6-terra\" \"GPT-5.6 Terra\")
           (model \"gpt-5.6-luna\"  \"GPT-5.6 Luna\")
           (model \"gpt-5.5\"       \"GPT-5.5\"))))

     ;; ── MCP servers — manage in the /mcp modal (⌃O). Each is a value. ──
     :mcp-servers
     (list
       ;; Sema's own MCP server: gives the agent eval + docs into Sema itself.
       ;; On by default — comment out this line to disable it.
       (mcp-server \"sema\" {:command \"sema\" :args [\"mcp\" \"--include\" \"eval,docs,docs_search\"]
                           :autostart #t})
       ;; (mcp-server \"fs\"    {:command \"npx\" :args [\"-y\" \"@modelcontextprotocol/server-filesystem\" \".\"]})
       ;; (mcp-server \"asana\" {:url \"https://mcp.asana.com/mcp\"})   ; OAuth when you connect
       )   ; only add servers you trust — they run real commands / reach real services

     ;; ── Slash commands — argv (no shell), or a Lisp handler. ──
     ;; :key gives a command a keyboard shortcut, e.g. ctrl-t → /test.
     :commands
     (list
       (command \"test\" {:desc \"run tests\" :run [\"make\" \"test\"] :key \"ctrl-t\"})
       ;; (command \"log\" {:desc \"git log\" :run [\"git\" \"log\" \"--oneline\" \"-n\" :args]})
       )

     ;; ── Keybindings — rebind any action, or bind a key to a command name. ──
     ;; actions: :mcp :resume :palette :quit :interrupt :clear-line :line-start :line-end :repaint
     :keys {}   ;; e.g. {:mcp \"ctrl-p\" :test \"ctrl-t\"}
     }))
")

(defun ensure-config! ()
  "Write the annotated default init.sema if none exists. Returns the path."
  (let ((path (config-path)))
    (unless (file/exists? path)
      (file/mkdir (config-dir))
      (file/write path default-init-source))
    path))
