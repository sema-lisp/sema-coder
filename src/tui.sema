;; tui.sema — the full-screen (sema) coder terminal UI.
;;
;; A bespoke, hand-rendered TUI built directly on the host primitives:
;; alt-screen + cursor control (term/*), raw-mode key input
;; (io/tty-raw!, io/read-key-timeout), terminal size + resize (sys/term-size,
;; sys/on-signal :winch), and streaming agent turns (agent/run :on-text).
;;
;; Rendering model: every frame is rebuilt as a list of exactly
;; `*rows*` strings; we diff against the previous frame and rewrite only the rows
;; that changed — so there is no full-screen clear and no flicker. All output
;; goes through one stream (stdout via `display`) so cursor moves and content
;; never interleave out of order.
;;
;; Concurrency model: an agent turn runs as an async task; agent/run's LLM and
;; tool I/O offload to the runtime pool and yield cooperatively, so a sibling
;; "pump" task keeps the UI alive for the whole turn — keys are polled
;; non-blocking (scroll, resize, and type-ahead all keep working while tokens
;; stream in) and Ctrl-C cancels the turn task cleanly via async/cancel.
;;
;; Module layout: text.sema (width-aware string helpers), keymap.sema
;; (bindings), transcript.sema (blocks → styled lines), overlay.sema (the
;; MCP + resume modals). This file owns the shared UI state, the frame/diff
;; renderer, input, the agent turn, and session persistence.

(load "commands.sema")   ;; brings in theme, config, agent, tools, display, util
(load "text.sema")
(load "keymap.sema")
(load "transcript.sema")
(load "overlay.sema")

;; ── Terminal control as strings (emitted through one stream) ─────────────────

(define ESC "\x1b;")
(defun goto (row col) (string/append ESC "[" (number->string row) ";" (number->string col) "H"))
(define CLEAR-LINE (string/append ESC "[2K"))
(define SHOW-CURSOR (string/append ESC "[?25h" ESC "[6 q"))  ;; show + steady bar (no blink)
(define HIDE-CURSOR (string/append ESC "[?25l"))
(define RESET-CURSOR (string/append ESC "[0 q"))            ;; restore terminal default on exit

;; ── Mutable UI state ─────────────────────────────────────────────────────────

(define *rows* 24)
(define *cols* 80)
(define *cwd* ".")
(define *model* "")
(define *effort* "")        ;; /effort override; "" = config, then provider default
(define *agent* #f)
(define *config* {})
(define *messages* '())
(define *input* "")
(define *cursor* 0)         ;; caret index into *input* (codepoints)
(define *scroll* 0)         ;; lines scrolled up from the bottom (0 = follow tail)
(define *psel* 0)           ;; selected index in the slash palette
(define *busy* #f)          ;; an agent turn is in flight
(define *turn* #f)          ;; promise for the in-flight turn (#f when idle)
(define *interrupt* #f)     ;; the user asked to cancel the current turn
(define *type-buffer* "")   ;; received-but-not-yet-revealed text (typewriter)
(define *should-quit* #f)
(define *last-frame* '())   ;; previous frame's rows, for diffing
(define *config-watcher* #f)  ;; fs/watch handle on the config dir
(define *config-error* #f)    ;; string while the last reload failed (persistent banner)
(define *reload-at* 0)        ;; debounce: reload once the change settles (0 = idle)
(define *session-id* #f)      ;; current session's file id (persisted after each turn)
(define *session-created* 0)  ;; its creation timestamp (ms)
(define *persist-warned* #f)  ;; emitted at most one persist-failure warning per session

;; The key loop must read the quit flag through a function call: on current
;; sema releases, a direct global read inside a recursive loop in a `load`ed
;; unit never observes a cross-function set! (fresh invocations do — hence
;; the accessor).
(defun should-quit? () *should-quit*)

;; ── Palette (slash popup: command names, then argument completions) ──────────
;; "/mod"        → command mode: fuzzy over registered command names.
;; "/model opu"  → argument mode (when the command registered completions):
;;                 fuzzy over its entries, shown as "Provider: Model Name".

(defun palette-open? () (string/starts-with? *input* "/"))

(defun palette-query ()
  (let* ((rest (string/slice *input* 1 (string/length *input*)))
         (sp   (string/index-of rest " ")))
    (if sp (string/slice rest 0 sp) rest)))

(defun all-command-entries ()
  "Every command as {:name :desc}, in registration order. Config-declared
   commands are already in the registry (reconciled at boot/reload)."
  (map (lambda (n) {:name n :desc (get (get *commands* n {}) :desc "")}) *command-order*))

(defun fuzzy-score (query item)
  "Subsequence score (case-insensitive); #f if QUERY isn't a subsequence of ITEM."
  (if (= query "") 0
    (let ((q (string/lower query)) (it (string/lower item)))
      (let loop ((qi 0) (ii 0) (score 0) (streak 0))
        (cond
          ((>= qi (string/length q)) score)
          ((>= ii (string/length it)) #f)
          ((equal? (string/slice q qi (+ qi 1)) (string/slice it ii (+ ii 1)))
            (loop (+ qi 1) (+ ii 1) (+ score (+ 1 streak) (if (= ii 0) 3 0)) (+ streak 1)))
          (else (loop qi (+ ii 1) score 0)))))))

(defun palette-matches ()
  ;; Score every command, drop non-matches, best-first, then unwrap to entries.
  (let ((q (palette-query)))
    (->> (all-command-entries)
         (map #(list (fuzzy-score q (:name %)) %))
         (filter #(nth % 0))
         (sort-by #(- (nth % 0)))
         (map #(nth % 1)))))

(defun palette-arg-context ()
  "When the input reads \"/cmd <partial>\" and /cmd registered argument
   completions, {:cmd name :query partial}; else #f."
  (let ((sp (string/index-of *input* " ")))
    (when (and (palette-open?) sp)
      (let ((name (string/slice *input* 1 sp)))
        (when (command-has-completions? name)
          {:cmd   name
           :query (string/trim (string/slice *input* sp (string/length *input*)))})))))

(defun arg-score (q e)
  "Best fuzzy score of Q against an entry's :label or :value; #f if neither."
  (let ((a (fuzzy-score q (:label e)))
        (b (fuzzy-score q (:value e))))
    (cond ((and a b) (max a b))
          (a a)
          (else b))))

(defun arg-matches (ctx)
  (->> (command-completions (:cmd ctx) (tui-state))
       (map #(list (arg-score (:query ctx) %) %))
       (filter #(nth % 0))
       (sort-by #(- (nth % 0)))
       (map #(nth % 1))))

(defun palette-view ()
  "The open palette's contents — {:mode :commands|:args :title :entries [:ctx]}
   — or #f when the palette is closed."
  (when (palette-open?)
    (if-let (ctx (palette-arg-context))
      {:mode :args :title (:cmd ctx) :ctx ctx :entries (arg-matches ctx)}
      {:mode :commands :title "commands" :entries (palette-matches)})))

(defun palette-entries ()
  (if-let (pv (palette-view)) (:entries pv) '()))

(defun palette-choice (pv sel input)
  "The command string Enter should run for palette PV, selection SEL, and the
   raw INPUT. Pure — on-enter dispatches the result. In argument mode an
   exactly-typed value (or no match at all, e.g. a custom model id) runs as
   typed; otherwise the selection runs."
  (if (equal? (:mode pv) :args)
    (let* ((entries (:entries pv))
           (typed   (:query (:ctx pv)))
           (exact?  (any #(= (:value %) typed) entries)))
      (if (or exact? (null? entries))
        input
        f"/${(:cmd (:ctx pv))} ${(:value (nth entries (min sel (- (length entries) 1))))}"))
    (let* ((matches (:entries pv))
           (parsed  (parse-command input))
           ;; If the typed name is itself a command, run it; else run the selection.
           (known?  (get *commands* (:name parsed) #f)))
      (cond (known? input)
            ((> (length matches) 0)
             (string/append "/" (:name (nth matches (min sel (- (length matches) 1))))
                            (if (= (:args parsed) "") "" (string/append " " (:args parsed)))))
            (else input)))))

(defun palette-completion (pv sel)
  "The input Tab should complete to for PV/SEL, or #f when nothing matches."
  (let ((entries (:entries pv)))
    (when (> (length entries) 0)
      (let ((e (nth entries (min sel (- (length entries) 1)))))
        (if (equal? (:mode pv) :args)
          f"/${(:cmd (:ctx pv))} ${(:value e)}"
          (string/append "/" (:name e) " "))))))

(defun palette-limit (matches) (min 8 (length matches)))

(defun palette-row (mode e inner)
  "One palette row as plain text; palette-box styles selection afterwards.
   An :active entry (the value currently in effect) is marked with ●."
  (if (equal? mode :args)
    (string/append (string/pad-right (:label e) 30) " "
                   (clip-width (:value e) (max 4 (- inner 35)))
                   (if (get e :active #f) " ●" ""))
    (string/append (string/pad-right (string/append "/" (:name e)) 12) " "
                   (clip-width (:desc e) (max 4 (- inner 15))))))

(defun palette-box (pv sel bw)
  "Render the palette PV as a bordered box of outer width BW: gold parens/label,
   faint borders, the selected row in accent. Returns a list of styled lines."
  (let* ((entries (:entries pv))
         (shown (take (palette-limit entries) entries))
         (inner (max 8 (- bw 4)))                 ;; text width inside │ … │
         (label f" ${(:title pv)} ")
         (top (string/append (faint "┌") (accent-dim label)
                             (faint (string/append (string/repeat "─" (max 0 (- bw 2 (string/length label)))) "┐"))))
         (bot (faint (string/append "└" (string/repeat "─" (max 0 (- bw 2))) "┘")))
         (rows (enumerate-map
                 (lambda (i e)
                   (let* ((sel?  (= i sel))
                          (txt   (fit-plain (string/append (if sel? "▸ " "  ")
                                                           (palette-row (:mode pv) e (- inner 2))) inner))
                          (body  (if sel? (accent txt) (muted txt))))
                     (string/append (faint "│ ") body (faint " │"))))
                 shown)))
    (map indent (append (list top) rows (list bot)))))

;; ── Frame assembly ───────────────────────────────────────────────────────────

(defun transcript-height () (max 1 (- *rows* 3)))

(defun max-scroll ()
  "How far up the transcript can scroll before the top line is on screen."
  (max 0 (- (length (transcript-lines (- *cols* 2))) (transcript-height))))

(defun scroll-by! (n)
  "Scroll by N lines (positive = toward older), clamped to [0, max-scroll].
   Clamping on write (not just at render) keeps scroll-down responsive after
   the user over-scrolls past the top."
  (set! *scroll* (max 0 (min (+ *scroll* n) (max-scroll)))))

(defun round1 (x) (/ (round (* x 10)) 10.0))    ;; one decimal place

(defun fmt-count (n)
  ;; Bucket AFTER rounding so 999_960 reads "1.0M", not "1000.0k".
  (cond ((>= n 1000000) f"${(round1 (/ n 1000000.0))}M")
        ((>= n 1000)    (let ((k (round1 (/ n 1000.0))))
                          (if (>= k 1000) "1.0M" f"${k}k")))
        (else           (number->string n))))

(defun effective-model ()
  "The session override if set, else the config's model (so a reload shows)."
  (if (not (= *model* "")) *model* (get *config* :model "")))

(defun effective-effort ()
  "The /effort override if set, else the active model's :effort default, else
   the config's :effort (so a reload shows)."
  (pick-effort *effort* (effective-model) *config*))

(defun header-line ()
  ;; Token counts come from llm/session-usage — the cumulative sum across every
  ;; provider round (llm/last-usage would report only a turn's final round).
  (let* ((u     (llm/session-usage))
         (cost  (get u :cost-usd 0.0))
         (right (muted (string/join
                         (append
                           (list (let ((m (effective-model))) (if (= m "") "auto" m)))
                           (let ((e (effective-effort))) (if (= e "") '() (list f"effort ${e}")))
                           (list f"↑${(fmt-count (get u :prompt-tokens 0))} ↓${(fmt-count (get u :completion-tokens 0))}")
                           (if (> cost 0.0)
                             (list f"$${(/ (round (* cost 10000)) 10000.0)}")
                             '()))
                         " · ")))
         (left  (string/append " " (wordmark-with "coder")))
         (gap   (max 1 (- *cols* (string/width left) (string/width right) 1))))
    (string/append left (string/repeat " " gap) right)))

(define spinner-frames ["⠋" "⠙" "⠹" "⠸" "⠼" "⠴" "⠦" "⠧" "⠇" "⠏"])
(defun spinner-frame () (nth spinner-frames (mod (quotient (time-ms) 80) 10)))

(defun status-line ()
  ;; A persistent config-error banner (until the next clean reload), else a
  ;; spinner while a turn runs, else a scroll indicator, else nothing.
  (indent (cond
    (*config-error* (bad "⚠ config error — using last good (fix init.sema)"))
    (*busy*         (faint (string/append (spinner-frame) " evaluating · ctrl-c interrupts")))
    ((> *scroll* 0) (faint f"↕ scrolled +${*scroll*}"))
    (else           ""))))

(defun prompt-view ()
  "Window the input so the caret is always visible (input starts at column 4).
   The window is measured in DISPLAY WIDTH — walk left from the caret until the
   caret-to-here span fills the available columns, then extend right as far as
   still fits — so `shown` never exceeds the row and wide chars can't overflow
   the fixed-row diff model."
  (let* ((avail (max 4 (- *cols* 4)))
         (len   (string/length *input*))
         (cw    #(string/width (string/slice *input* % (+ % 1))))
         (start (let loop ((i *cursor*) (w 0))
                  (if (<= i 0) 0
                    (let ((wprev (cw (- i 1))))
                      (if (> (+ w wprev) avail) i (loop (- i 1) (+ w wprev)))))))
         (end   (let loop ((i *cursor*) (w (string/width (string/slice *input* start *cursor*))))
                  (if (>= i len) len
                    (if (> (+ w (cw i)) avail) i (loop (+ i 1) (+ w (cw i))))))))
    {:text (string/slice *input* start end)
     :caret-col (min *cols* (+ 4 (string/width (string/slice *input* start *cursor*))))}))

(defun prompt-line ()
  (indent (string/append (accent (string/append prompt-glyph " ")) (:text (prompt-view)))))

(defun viewport (lines h)
  "Take the last H lines, honoring *scroll* (0 = bottom). Pad with blanks on top."
  (let* ((n (length lines))
         (maxscroll (max 0 (- n h)))
         (sc (min *scroll* maxscroll))
         (end (- n sc))
         (start (max 0 (- end h)))
         (window (if (> n 0) (take (- end start) (drop start lines)) '()))
         (pad (- h (length window))))
    (if (> pad 0) (append (make-list pad "") window) window)))

(defun overlay-bottom (base over)
  "Replace the last (length OVER) rows of BASE with OVER."
  (let* ((n (length base)) (k (min (length over) n)))
    (append (take (- n k) base) (drop (- (length over) k) over))))

(defun build-frame ()
  ;; Content width leaves 1 char of padding on BOTH sides (indent adds the left
  ;; space; wrapping to *cols*-2 leaves the right gap) so text feels less cramped.
  (let* ((h (transcript-height))
         (tlines (viewport (transcript-lines (- *cols* 2)) h))
         (pv (palette-view))
         (body (if pv
                 (overlay-bottom tlines (palette-box pv *psel* (- *cols* 3)))
                 tlines))
         (rows (append (list (header-line)) body (list (prompt-line)) (list (status-line))))
         (rows (fit-rows rows *rows*))
         (rows (if (overlay-active?) (overlay-center rows (overlay-rows)) rows))
         ;; An overlay taller than the terminal yields more than *rows* rows;
         ;; re-clamp so render! never writes past the bottom and desyncs the diff.
         (rows (fit-rows rows *rows*)))
    ;; Normalize to exactly *rows* padded strings.
    (map #(pad-to % *cols*) rows)))

(defun fit-rows (rows n)
  (let ((have (length rows)))
    (cond ((= have n) rows)
          ((> have n) (take n rows))
          (else (append rows (make-list (- n have) ""))))))

;; ── Diff render ──────────────────────────────────────────────────────────────

(defun frame-ref (f i) (if (< i (length f)) (nth f i) ""))

(defun render! ()
  (let* ((frame (build-frame))
         (updates (enumerate-map
                    (lambda (i new)
                      (if (equal? new (frame-ref *last-frame* i)) ""
                        (string/append (goto (+ i 1) 1) CLEAR-LINE new)))
                    frame)))
    ;; One write: the changed rows, park + show the cursor at the prompt caret
    ;; (hidden while a modal is up, since the prompt is behind it).
    (display (string/append (apply string/append updates)
                            (goto (- *rows* 1) (:caret-col (prompt-view)))
                            (if (overlay-active?) HIDE-CURSOR SHOW-CURSOR)))
    (io/flush)
    (set! *last-frame* frame)))

(defun full-repaint! () (set! *last-frame* '()) (render!))

;; ── Typewriter reveal (streaming callbacks fire inside the agent task) ───────
;; Network deltas land in *type-buffer*; the pump reveals them at a steady
;; per-tick pace so display cadence is smooth regardless of burstiness, and the
;; whole transcript re-renders on the 16ms tick, not on every token.

(defun on-text-cb (delta)
  (when (> (string/length delta) 0)
    (set! *type-buffer* (string/append *type-buffer* delta))))

(defun reveal-tick! ()
  "Move a chunk of *type-buffer* into the streaming block. #t if it revealed.
   Reveals ~a third of the pending text (min 5 chars) so it catches up on bursts
   but types char-by-char as it drains."
  (let ((len (string/length *type-buffer*)))
    (if (= len 0) #f
      (let* ((n (min len (max 5 (quotient len 3))))
             (chunk (string/slice *type-buffer* 0 n)))
        (set! *type-buffer* (string/slice *type-buffer* n len))
        (append-assistant! chunk)
        #t))))

(defun flush-type-buffer! ()
  "Reveal everything pending at once (block boundaries, interrupts, errors)."
  (when (> (string/length *type-buffer*) 0)
    (append-assistant! *type-buffer*)
    (set! *type-buffer* "")))

(defun on-tool-cb (event)
  (flush-type-buffer!)   ;; land any pending text before the tool block / next segment
  (let (({:event evt :tool tool :args args} event))
    (cond
      ((= evt "start")
        (let ((arg (tool-arg tool (if (map? args) args {}))))
          (add-block! {:kind :tool :tool tool :arg arg :state :running :ms 0})))
      ((= evt "end")
        (set-last-tool-done! (get event :duration-ms 0) (get event :result "") (get event :error #f))
        (add-block! {:kind :assistant :text ""}))))   ;; target for post-tool text
  (render!))

;; ── Running a turn ───────────────────────────────────────────────────────────
;; The turn is an async task; `pump-input!` is its sibling. The top-level
;; `await` drives both: agent/run's network rounds park on the runtime pool,
;; and every park is a chance for the pump to poll keys and repaint. Ctrl-C
;; cancels the turn task (see handle-ctrl) instead of throwing from inside a
;; streaming callback.

(defun pump-input! (turn)
  ;; Best-effort UI sibling of the turn task: it's spawned and cancelled, never
  ;; awaited, so a throw here would be swallowed and freeze updates for the rest
  ;; of the turn. Guard each pass so one bad key/frame can't stop the pump; the
  ;; turn's own await/catch owns real errors.
  (let loop ()
    (when (or (async/pending? turn) (> (string/length *type-buffer*) 0))
      (try
        (begin
          (check-resize!)
          (let drain ()
            (let ((k (io/read-key-timeout 0)))
              (when k (handle-key k) (drain))))
          (reveal-tick!)
          (render!))
        (catch e nil))
      (async/sleep 16)
      (loop))))

(defun run-agent-turn! (text)
  (set! *interrupt* #f)
  (set! *busy* #t)
  (set! *type-buffer* "")
  ;; The empty assistant block is the streaming target for :on-text.
  (add-block! {:kind :assistant :text ""})
  (render!)
  (let* ((turn (async (run-turn-streaming *agent* text *messages* on-tool-cb on-text-cb (effective-effort))))
         (pump (async (pump-input! turn))))
    (set! *turn* turn)
    (let ((result (try (await turn)
                    (catch e
                      (if *interrupt*
                        (begin (set! *type-buffer* "") (add-block! {:kind :info :text "interrupted"}))
                        (begin (flush-type-buffer!)
                               (add-block! {:kind :error :text (str (get e :message (str e)))})))
                      #f))))
      (await pump)   ;; drain the remaining buffer at the typewriter pace
      (set! *turn* #f)
      (set! *busy* #f)
      (when result (set! *messages* (:messages result)) (persist-session!))
      (render!))))

;; ── Session persistence + restore ────────────────────────────────────────────
;; Every turn writes the whole conversation to <config>/sessions/<id>.jsonl (the
;; exact agent/run :messages shape), so /resume can reload it and continue.

(defun new-session! ()
  ;; timestamp + pid: two instances started in the same millisecond can't
  ;; silently share (and clobber) one session file.
  (set! *session-id* f"${(time-ms)}-${(sys/pid)}")
  (set! *session-created* (time-ms)))

(defun persist-session! ()
  (when *session-id*
    (try (save-session! *session-id* *session-created* (effective-model) (effective-effort) *messages*)
      (catch e
        (unless *persist-warned*
          (set! *persist-warned* #t)
          (add-block! {:kind :warn :text f"session not saved: ${e} — check disk space and permissions"}))))))

(defun restore-session! (id)
  (try
    (let (({:keys [meta messages]} (load-session id)))
      (set! *messages* messages)
      (set! *session-id* id)
      (set! *session-created* (get meta :created (time-ms)))
      (set! *persist-warned* #f)
      ;; Resume the session's model + effort too, and rebuild the agent on them —
      ;; a resumed conversation continues on what it was actually running.
      (set! *model*  (get meta :model ""))
      (set! *effort* (get meta :effort ""))
      (set! *agent*  (create-agent *cwd* *model* *config*))
      (clear-transcript!)
      (for-each add-block! (messages->blocks messages))
      (add-block! {:kind :info :text f"resumed “${(get meta :title id)}” · ${(length messages)} messages · ${(let ((m (get meta :model ""))) (if (= m "") "auto" m))}"})
      (set! *scroll* 0))
    (catch e
      (add-block! {:kind :error :text f"failed to restore session: ${e}"}))))

;; ── Commands (dispatched through the shared registry) ────────────────────────
;; The TUI parameterizes the emit sink so registry handlers — including any
;; the user registers with register-command! — render into the transcript.

(defun tui-emit (kind text)
  (if (equal? kind :clear)
    (clear-transcript!)
    (add-block! {:kind kind :text text})))

(defun tui-state ()
  {:messages *messages* :model *model* :effort *effort*
   :cwd *cwd* :agent *agent* :config *config*})

(defun apply-tui-state! (st)
  (let ((cleared? (and (> (length *messages*) 0) (null? (:messages st)))))
    (set! *messages* (:messages st))
    (set! *model*    (:model st))
    (set! *effort*   (get st :effort ""))
    (set! *cwd*      (:cwd st))
    (set! *agent*    (:agent st))
    (set! *config*   (:config st))
    ;; A command that emptied the conversation (/clear) starts a fresh session,
    ;; so the next turn writes a new file instead of overwriting the one the
    ;; just-cleared conversation was persisted under.
    (when cleared? (new-session!))))

(defun run-command! (input)
  ;; A throwing handler (a user-registered command, or /model on a bad model)
  ;; becomes an error block instead of killing the app.
  (let ((next (try
                (parameterize ((current-emit tui-emit))
                  (dispatch-command (parse-command input) (tui-state)))
                (catch e
                  (add-block! {:kind :error :text f"command failed: ${(get e :message (str e))}"})
                  (tui-state)))))
    (if (equal? next 'quit)
      (set! *should-quit* #t)
      (apply-tui-state! next))))

;; ── Key handling ─────────────────────────────────────────────────────────────

(defun insert-char! (ch)
  (set! *input* (string/append (string/slice *input* 0 *cursor*) ch
                               (string/slice *input* *cursor* (string/length *input*))))
  (set! *cursor* (+ *cursor* (string/length ch)))
  (set! *psel* 0))

(defun backspace! ()
  (when (> *cursor* 0)
    (set! *input* (string/append (string/slice *input* 0 (- *cursor* 1))
                                 (string/slice *input* *cursor* (string/length *input*))))
    (set! *cursor* (- *cursor* 1))
    (set! *psel* 0)))

(defun forward-delete! ()
  "Delete the codepoint AT the cursor (the Delete / Fn+Delete key)."
  (when (< *cursor* (string/length *input*))
    (set! *input* (string/append (string/slice *input* 0 *cursor*)
                                 (string/slice *input* (+ *cursor* 1) (string/length *input*))))
    (set! *psel* 0)))

(defun delete-word-backward! ()
  "Delete from the previous word boundary up to the cursor (Option+Delete)."
  (let ((start (word-left-index *input* *cursor*)))
    (when (< start *cursor*)
      (set! *input* (string/append (string/slice *input* 0 start)
                                   (string/slice *input* *cursor* (string/length *input*))))
      (set! *cursor* start)
      (set! *psel* 0))))

(defun word-left! ()  (set! *cursor* (word-left-index *input* *cursor*)))
(defun word-right! () (set! *cursor* (word-right-index *input* *cursor*)))

(defun clear-input! () (set! *input* "") (set! *cursor* 0) (set! *psel* 0))

(defun on-enter ()
  ;; Ignored while a turn is in flight — typed text stays in the prompt as
  ;; type-ahead for the next turn.
  (unless *busy*
    (let ((text (string/trim *input*)))
      (cond
        ((= text "") nil)
        ((palette-open?)
          (let ((chosen (palette-choice (palette-view) *psel* *input*)))
            (clear-input!)
            (run-command! chosen)))
        (else
          (add-block! {:kind :user :text text})
          (clear-input!)
          (set! *scroll* 0)          ;; sending always returns you to the tail
          (run-agent-turn! text))))))

(defun run-key-command! (action)
  "A key bound to a non-built-in action fires the like-named custom command, so
   :keys {:test \"ctrl-t\"} runs /test. Ignored mid-turn (like a typed command)."
  (when (and action (not *busy*))
    (let ((name (keyword->string action)))
      (when (get *commands* name #f)
        (run-command! (string/append "/" name))))))

(defun handle-ctrl (ch)
  (match (keymap-action (string/append "ctrl-" ch))
    (:interrupt
      (cond
        (*busy* (set! *interrupt* #t) (when *turn* (async/cancel *turn*)))
        ((> (string/length *input*) 0) (clear-input!))
        (else (set! *should-quit* #t))))
    (:quit       (unless *busy* (set! *should-quit* #t)))
    (:palette    (set! *input* "/") (set! *cursor* 1) (set! *psel* 0))
    ;; No overlay while a turn runs: a restore/reconnect mid-turn would race the
    ;; finishing turn, which then overwrites *messages* and persists onto the
    ;; wrong session file. (Typed /mcp and /resume are already gated by on-enter.)
    (:mcp        (unless *busy* (open-mcp-modal!)))
    (:resume     (unless *busy* (open-resume-modal!)))
    (:clear-line (clear-input!))
    (:line-start (set! *cursor* 0))
    (:line-end   (set! *cursor* (string/length *input*)))
    (:repaint    (full-repaint!))
    (action      (run-key-command! action))))

(defun word-motion? (k)
  "A held Option (alt) or Ctrl modifier turns arrow motion into word motion."
  (let ((mods (get k :mods '())))
    (or (member :alt mods) (member :ctrl mods))))

(defun handle-named (k)
  (match (:name k)
    (:enter     (on-enter))
    (:backspace (backspace!))
    (:delete    (forward-delete!))
    (:left      (if (word-motion? k) (word-left!)  (set! *cursor* (max 0 (- *cursor* 1)))))
    (:right     (if (word-motion? k) (word-right!) (set! *cursor* (min (string/length *input*) (+ *cursor* 1)))))
    (:home      (set! *cursor* 0))
    (:end       (set! *cursor* (string/length *input*)))
    (:tab
      (when (palette-open?)
        (when-let (s (palette-completion (palette-view) *psel*))
          (set! *input* s)
          (set! *cursor* (string/length *input*))
          (set! *psel* 0))))
    (:up
      (if (palette-open?) (set! *psel* (max 0 (- *psel* 1)))
        (scroll-by! 1)))
    (:down
      (if (palette-open?)
        (set! *psel* (min (+ *psel* 1)
                          (max 0 (- (palette-limit (palette-entries)) 1))))
        (scroll-by! -1)))
    (:page-up   (scroll-by! (transcript-height)))
    (:page-down (scroll-by! (- (transcript-height))))
    (:esc       (when (palette-open?) (clear-input!)))
    (_ nil)))

(defun handle-mouse (k)
  ;; Wheel scrolls the transcript; other mouse events are ignored for now.
  (match (:action k)
    (:wheel-up   (scroll-by! 3))
    (:wheel-down (scroll-by! -3))
    (_ nil)))

(defun handle-alt (k)
  ;; Option+Delete arrives as Alt+DEL (0x7f) → delete the word before the cursor.
  (when (= (:char k) "\u007f") (delete-word-backward!)))

(defun handle-key (k)
  (if (overlay-active?)
    (handle-overlay-key k)
    (match (:kind k)
      (:ctrl  (handle-ctrl (:char k)))
      (:key   (handle-named k))
      (:alt   (handle-alt k))
      (:char  (insert-char! (:char k)))
      (:mouse (handle-mouse k))
      (_ nil))))

;; ── Resize ───────────────────────────────────────────────────────────────────

(define *resize-pending* #t)

(defun recompute-size! ()
  (let ((sz (sys/term-size)))
    (when (map? sz)
      (set! *rows* (max 6 (:rows sz)))
      (set! *cols* (max 20 (:cols sz)))))
  (set! *resize-pending* #f))

(defun check-resize! ()
  (sys/check-signals)
  (when *resize-pending* (recompute-size!) (full-repaint!)))

;; ── Config hot-reload (watch the dir, debounce, reconcile) ────────────────────
;; Watch the config *directory* (basename-filter init.sema) so atomic-rename
;; saves are caught cross-platform, and debounce the event burst a save fires.

(defun start-config-watch! ()
  (set! *config-watcher* (try (fs/watch (config-dir) {}) (catch e #f))))

(defun config-touched? ()
  (if (not *config-watcher*) #f
    (let ((evs (try (fs/watch-events *config-watcher*) (catch e '()))))
      (any (lambda (ev)
             (any #(string/ends-with? % "init.sema") (get ev :paths '())))
           evs))))

(defun warn-keymap-conflicts! ()
  (let ((dups (keymap-conflicts)))
    (unless (null? dups)
      (add-block! {:kind :warn
                   :text f"keymap: ${(string/join dups ", ")} bound to more than one action — first match wins"}))))

(defun reload-config! ()
  (ensure-config!)
  (let ((r (load-config (config-path))))
    (if (:ok r)
      (let ((cfg (:ok r)))
        (set! *config-error* #f)
        (reconcile-commands! (:commands cfg))
        (reconcile-servers! (:mcp-servers cfg))
        (mcp-autostart!)   ;; connect any newly-declared :autostart servers
        (set! *config* cfg)
        (set! *agent* (create-agent *cwd* *model* cfg))
        (add-block! {:kind :ok :text f"config reloaded · model → ${(if (= (:model cfg) "") "auto" (:model cfg))}"})
        (warn-keymap-conflicts!))
      (set! *config-error* (str (:error r)))))
  (render!))

(defun poll-config! ()
  ;; A save fires a burst (create + several modifies) and can be mid-write, so
  ;; arm a deadline on any touch and reload only once it settles.
  (when (config-touched?) (set! *reload-at* (+ (time-ms) 150)))
  (when (and (> *reload-at* 0) (>= (time-ms) *reload-at*))
    (set! *reload-at* 0)
    (reload-config!)))

;; ── Entry point ──────────────────────────────────────────────────────────────

(defun tui-run (cwd model cfg agent)
  (set! *cwd* cwd) (set! *model* model) (set! *config* cfg) (set! *agent* agent)
  (set! *tui-active* #t)
  (new-session!)
  (recompute-size!)
  (sys/on-signal :winch (lambda () (set! *resize-pending* #t)))
  ;; The guards restore raw mode, the alt screen, the cursor, and mouse reporting
  ;; on ANY exit — normal or via a thrown error — so a crash can't leave the
  ;; terminal broken. (mouse wheel scrolls the transcript → {:kind :mouse}.)
  (io/with-raw-mode
    (term/with-alt-screen
      (term/with-mouse
        (term/set-title "(sema) coder")
        (add-block! {:kind :info :text f"(sema) coder — ${cwd} · ${(if (= model "") "auto" model)}"})
        (add-block! {:kind :info :text f"type / for commands · ${(key-hint :mcp)} MCP · ${(key-hint :resume)} resume · ${(key-hint :palette)} palette · ${(key-hint :quit)} quit"})
        (add-block! {:kind :info :text f"; ${(epigraph)}"})
        (warn-keymap-conflicts!)
        (let ((na (mcp-needs-auth)))
          (unless (null? na)
            (add-block! {:kind :warn :text f"${(length na)} MCP server(s) need auth: ${(string/join na ", ")} — ${(key-hint :mcp)} to sign in"})))
        (start-config-watch!)
        (full-repaint!)
        (let loop ()
          (check-resize!)
          (poll-config!)
          (let ((k (io/read-key-timeout 250)))
            (when k
              (handle-key k)
              ;; Coalesce a burst (e.g. rapid wheel events) into one render.
              (let drain () (let ((k2 (io/read-key-timeout 0)))
                              (when k2 (handle-key k2) (drain))))
              (render!)))
          (unless (should-quit?) (loop))))))
  ;; Back on the main screen — a quiet sign-off in the scrollback.
  (io/println-error (faint f"   ; ${goodbye-line}"))
  (display RESET-CURSOR)
  (io/flush))
