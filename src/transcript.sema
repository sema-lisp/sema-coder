;; transcript.sema — the TUI's conversation transcript: block storage, block →
;; styled-line rendering, and the rendered-line cache.
;;
;; The transcript is a mutable array so streaming is O(1) per token: every
;; :on-text delta rewrites the last block in place instead of rebuilding the
;; whole list. Rendered lines are cached and recomputed only when the content
;; or width changes — so scrolling (which only re-windows) never re-parses
;; markdown.

(load "theme.sema")
(load "text.sema")
(load "markdown.sema")

;; ── Block storage + mutation ─────────────────────────────────────────────────

(define *transcript* (mutable-array/new 64))   ;; blocks, oldest → newest

(define *tlines* '())
(define *tlines-w* -1)
(define *tlines-dirty* #t)
(defun mark-tdirty! () (set! *tlines-dirty* #t))

(defun add-block! (b) (mutable-array/push! *transcript* b) (mark-tdirty!))

(defun clear-transcript! () (set! *transcript* (mutable-array/new 64)) (mark-tdirty!))

(defun transcript-blocks () (mutable-array/->vector *transcript*))

(defun kind? (b k) (equal? (get b :kind :none) k))

(defun update-last! (f)
  (let ((n (mutable-array/length *transcript*)))
    (when (> n 0)
      (mutable-array/set! *transcript* (- n 1)
        (f (mutable-array/get *transcript* (- n 1))))
      (mark-tdirty!))))

(defun last-block ()
  (let ((n (mutable-array/length *transcript*)))
    (if (> n 0) (mutable-array/get *transcript* (- n 1)) #f)))

(defun append-assistant! (delta)
  (let ((lb (last-block)))
    (if (and lb (kind? lb :assistant))
      (update-last! #(assoc % :text (string/append (:text %) delta)))
      (add-block! {:kind :assistant :text delta}))))

(defun set-last-tool-done! (ms result err)
  (update-last! #(assoc % :state :done :ms ms :result result :error err)))

;; ── Block → styled lines ─────────────────────────────────────────────────────

(defun indent (line) (string/append " " line))

(defun fit-line (l w)
  "Indent one preformatted line, guaranteeing it fits width W. Keeps ANSI while
   it fits (the common case); only when a line is genuinely too wide for the
   terminal does it strip color and clip — so an over-wide row can never break
   the fixed-row diff model by soft-wrapping."
  (indent (if (<= (string/width l) w) l (clip-width (term/strip l) w))))

;; Delegates to the native, display-width-aware string/wrap (correct for CJK /
;; emoji / combining marks, which a char-count wrap gets wrong).
(defun wrap-text (text w) (string/word-wrap text w))

(defun tool-result-lines (b w)
  "A preview of a completed tool's result under its line — faint, or red if it
   errored. Shows the first :tool-preview-lines lines (config, default 5);
   anything longer collapses into a final “… +N lines” row."
  (let* ((r (get b :result ""))
         (s (if (string? r) r (str r)))
         (paint (if (get b :error #f) bad faint))
         (limit (max 1 (get *config* :tool-preview-lines 5)))
         (lines (string/split (string/trim-right s) "\n"))
         (shown (take (min limit (length lines)) lines))
         (extra (- (length lines) (length shown)))
         (pw    (max 4 (- w 6))))
    (if (= (string/trim s) "") '()
      (append
        (map #(indent (string/append "  " (paint (clip-width % pw)))) shown)
        (if (> extra 0)
          (list (indent (string/append "  " (faint f"… +${extra} lines"))))
          '())))))

(defun block-lines (b w)
  "Render one transcript block to a list of styled lines (content width W)."
  (match (get b :kind :none)
    (:user
      (append
        (map (lambda ([i l])
               (if (= i 0)
                 (indent (string/append (accent (string/append user-glyph " ")) (bright l)))
                 (indent (string/append "  " (bright l)))))
             (enumerate (wrap-text (:text b) (- w 2))))
        (list "")))
    (:assistant
      ;; Markdown-rendered. An empty assistant block (the pre-first-token
      ;; streaming target, or a post-tool round with no text) renders nothing.
      (if (= (string/trim (:text b)) "") '()
        (append (map indent (md-lines (:text b) w)) (list ""))))
    (:raw
      ;; Preformatted output (command stdout, pretty JSON): preserve internal
      ;; whitespace — split on newlines only, clip each line to width instead of
      ;; reflowing (word-wrap would collapse the spaces columns depend on).
      (append (map #(fit-line % w) (string/split (:text b) "\n"))
              (list "")))
    (:tool
      (let* ((tool (:tool b)) (arg (clip-width (get b :arg "") (max 4 (- w 18)))))
        (if (equal? (get b :state :done) :running)
          (list (indent (string/append (faint "·") " "
                                        (accent-dim (term/style tool :bold)) " " (muted arg))))
          (cons
            (indent (string/append (ok "✔") " "
                                   (accent-dim (term/style tool :bold)) " " (muted arg)
                                   " " (faint f"${(get b :ms 0)}ms")))
            (tool-result-lines b w)))))
    (:info  (map #(indent (muted %)) (wrap-text (:text b) w)))
    (:ok    (map #(indent (ok %)) (wrap-text (:text b) w)))
    (:warn  (map #(indent (warn %)) (wrap-text (:text b) w)))
    ;; Pre-styled chrome (help rows, /tools): keep its ANSI and column padding
    ;; intact — split on newlines only, never word-wrap; fit-line guards the
    ;; rare too-narrow-terminal overflow.
    (:line  (map #(fit-line % w) (string/split (:text b) "\n")))
    (:error (map #(indent (bad %)) (wrap-text (string/append "error: " (:text b)) w)))
    (_ '())))

(defun transcript-lines (w)
  (when (or *tlines-dirty* (not (= w *tlines-w*)))
    (set! *tlines* (->> (transcript-blocks)
                        (map #(block-lines % w))
                        (apply append)))
    (set! *tlines-w* w)
    (set! *tlines-dirty* #f))
  *tlines*)
