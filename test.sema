#!/usr/bin/env sema
;; test.sema — sema-coder's test runner, written in Sema: the coding agent's
;; test suite is driven by the language it is built in.
;;
;; Usage:
;;   ./test.sema                    run the whole suite
;;   ./test.sema -- markdown text   run only files whose name contains a term
;;   jake coder.test                same, from the repo or workspace root
;;
;; How it works:
;;   - A test is any tests/*_test.sema. Each loads tests/harness.sema, makes
;;     `check` calls, and ends with (done) — exiting non-zero on any failure.
;;   - Every file runs in a CHILD interpreter: a crash (or the harness's own
;;     exit) can't take the runner down, and no state leaks between files.
;;   - The child's exit code is the pass/fail truth; its "N checks, M failed"
;;     line is parsed for the per-file report. Full child output is shown
;;     only for failing files, so a green run stays quiet.
;;   - Exits 0 iff every selected file passed (CI gates on this).

(load "src/theme.sema")

;; ── Discovery ────────────────────────────────────────────────────
;; Paths resolve relative to this script (found via argv), not the cwd, so
;; the runner works from anywhere — repo root, workspace root, or elsewhere.

(defun script-dir ()
  (let loop ((rem (sys/args)))
    (cond ((null? rem) ".")
          ((string/ends-with? (car rem) "test.sema") (path/dir (car rem)))
          (else (loop (cdr rem))))))

(define tests-dir (path/join (script-dir) "tests"))

(defun name-filters ()
  "Everything after \"--\" in argv: substring filters on test names."
  (let loop ((rem (sys/args)))
    (cond ((null? rem) '())
          ((= (car rem) "--") (cdr rem))
          (else (loop (cdr rem))))))

(define filters (name-filters))

(defun wanted? (name)
  (or (null? filters) (any #(string/contains? name %) filters)))

(defun test-name (path)
  (let* ((parts (string/split path "/"))
         (base  (nth parts (- (length parts) 1))))
    (string/replace base "_test.sema" "")))

(defun test-files ()
  (->> (file/list tests-dir)
       (filter #(string/ends-with? % "_test.sema"))
       (map #(if (string/contains? % "/") % (path/join tests-dir %)))
       (filter #(wanted? (test-name %)))
       (sort)))

;; ── Running one file ─────────────────────────────────────────────

(defun parse-summary (err)
  "The harness's closing line → {:checks N :fails M}, or #f on a crash."
  (if-let (m (regex/match #"(\d+) checks, (\d+) failed" err))
    {:checks (string->number (nth (:groups m) 0))
     :fails  (string->number (nth (:groups m) 1))}
    #f))

(defun run-one (path)
  (let* ((t0  (time-ms))
         (res (shell "sema" path))
         (ms  (- (time-ms) t0))
         (err (get res :stderr "")))
    {:name    (test-name path)
     :ms      ms
     :ok      (= (get res :exit-code 1) 0)
     :summary (parse-summary err)
     :output  err}))

;; ── Report ───────────────────────────────────────────────────────

(defun report-row (r)
  (let* ((glyph  (if (:ok r) (ok "✔") (bad "✖")))
         (name   (string/pad-right (:name r) 19))
         (detail (if-let (s (:summary r))
                   (muted f"${(:checks s)} checks")
                   (bad "crashed")))                 ;; no summary line at all
         (time   (faint f"${(:ms r)}ms")))
    (io/println-error f"   ${glyph} ${(if (:ok r) (bright name) (bad name))} ${detail}  ${time}")))

(defun report-failure (r)
  (io/println-error "")
  (io/println-error (bad f"   ── ${(:name r)} ──"))
  (for-each
    #(io/println-error (string/append "   " %))
    (filter #(not (= (string/trim %) "")) (string/split (:output r) "\n")))
  (io/println-error ""))

;; ── Run ──────────────────────────────────────────────────────────

(io/println-error "")
(io/println-error (string/append "   " (wordmark-with "tests")))
(io/println-error (faint f"   ; ${(epigraph)}"))
(unless (null? filters)
  (io/println-error (muted f"   filter: ${(string/join filters ", ")}")))
(io/println-error "")

(define files (test-files))
(when (null? files)
  (io/println-error (bad f"   no tests match — see tests/*_test.sema"))
  (io/println-error "")
  (exit 1))

(define t0 (time-ms))
(define results (map run-one files))
(define elapsed (- (time-ms) t0))

(for-each report-row results)

(define failed  (filter #(not (:ok %)) results))
(define checks  (foldl (lambda (n r) (+ n (get (get r :summary {}) :checks 0))) 0 results))

(for-each report-failure failed)

(io/println-error "")
(io/println-error
  (if (null? failed)
    (string/append "   " (ok f"(✔ all green)")
                   (muted f" · ${(length results)} files · ${checks} checks · ${(/ elapsed 1000.0)}s"))
    (string/append "   " (bad f"(✖ ${(length failed)} of ${(length results)} files failed)")
                   (muted f" · ${checks} checks · ${(/ elapsed 1000.0)}s"))))
(io/println-error "")

(exit (if (null? failed) 0 1))
