(load "harness.sema")
(load "../src/tui.sema")

(set! *config* {})

(defun tool-block (result)
  {:kind :tool :tool "read-file" :arg "x" :state :done :ms 1 :result result :error #f})

(defun preview-lines (result)
  ;; block-lines row 0 is the ✔ header; the rest is the result preview.
  (cdr (block-lines (tool-block result) 60)))

;; default: up to 5 result lines, no counter when it all fits
(check "short result shows all lines" (length (preview-lines "a\nb\nc")) 3)
(check "five lines fit exactly"       (length (preview-lines "1\n2\n3\n4\n5")) 5)

;; longer than the limit: limit lines + one "… +N lines" row
(let ((rows (preview-lines "1\n2\n3\n4\n5\n6\n7")))
  (check "capped at limit + counter" (length rows) 6)
  (check-true "counter row present" (string/contains? (term/strip (nth rows 5)) "+2 lines")))

;; configurable via :tool-preview-lines
(set! *config* {:tool-preview-lines 1})
(let ((rows (preview-lines "1\n2\n3")))
  (check "limit 1 shows one line + counter" (length rows) 2)
  (check-true "counter counts the rest" (string/contains? (term/strip (nth rows 1)) "+2 lines")))
(set! *config* {})

;; empty results render nothing
(check "empty result renders nothing" (preview-lines "   ") '())

(done)
