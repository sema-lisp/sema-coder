;; audit_regressions_test.sema — guards for the bugs found in the code audit.
;; Each check fails against the pre-fix code, so a regression is caught here.

(load "harness.sema")
(load "../src/tui.sema")

;; ── #f-truthiness crashes: selection helpers must return nil (not #f) on an
;; empty modal, so the when-let guards in restore/connect skip instead of
;; calling (:id #f) / (:name #f) and throwing (which killed the whole TUI). ──
(set-overlay! {:kind :resume :view :list :sel 0 :sessions '()})
(check-true "resume-sel-session nil on empty" (nil? (resume-sel-session)))
(mcp-reset!)
(set-overlay! {:kind :mcp :view :list :sel 0 :tsel 0})
(check-true "mcp-sel-server nil on empty" (nil? (mcp-sel-server)))
(close-overlay!)

;; ── /clear must start a fresh session id, so the next turn writes a new file
;; instead of overwriting the just-cleared conversation's saved session. ──
(set! *messages* (list {:role "user" :content "hi"}))
(set! *session-id* "old-id")
(apply-tui-state! {:messages '() :model "" :effort "" :cwd "." :agent #f :config {}})
(check-true "clear starts a new session id" (not (= *session-id* "old-id")))
(check-true "new session id is set"         (if *session-id* #t #f))
;; a command that leaves messages non-empty must NOT rotate the session
(set! *session-id* "keep-id")
(apply-tui-state! {:messages (list {:role "user" :content "x"}) :model "" :effort ""
                   :cwd "." :agent #f :config {}})
(check "non-clearing command keeps session id" *session-id* "keep-id")

;; ── provider-key-missing? on an unknown provider returns #f without crashing
;; (the if-let/#f-truthiness guard), and the env-key map is correct. ──
(check "unknown provider → not missing" (provider-key-missing? "Nonesuch") #f)
(check "provider-env-key anthropic"     (provider-env-key "Anthropic") "ANTHROPIC_API_KEY")
(check "provider-env-key openai"        (provider-env-key "OpenAI") "OPENAI_API_KEY")
(check "provider-env-key unknown"       (provider-env-key "Nonesuch") #f)

(done)
