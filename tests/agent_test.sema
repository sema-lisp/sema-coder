(load "harness.sema")
(load "../agent.sema")   ;; loads util, tools

;; create-agent builds a real agent value (no network), with the base tools
(let ((a (create-agent "/tmp" "" {})))
  (check "agent has 7 tools" (length (agent/tools a)) 7))

;; model precedence (explicit arg) + max-turns from config; rebuilding is fine
(let ((b (create-agent "/tmp" "claude-haiku-4-5-20251001" {:max-turns 5})))
  (check "explicit model wins" (agent/model b) "claude-haiku-4-5-20251001")
  (check "max-turns from cfg"  (agent/max-turns b) 5))

;; tool names are derived from the tools themselves, not a hand-synced list
(check "tool-names derived" (tool-names) (map tool/name (all-tools)))
(check "seven tool names"   (length (tool-names)) 7)
(check-true "read-file present" (member "read-file" (tool-names)))

(done)
