(load "harness.sema")
(load "../src/tui.sema")

(set! *rows* 24) (set! *cols* 80) (set! *cwd* "/tmp") (set! *model* "")
(define d "/tmp/sc-hot-headless") (shell "rm" "-rf" d) (file/mkdir d)

(parameterize ((config-dir-override d))
  (file/write (config-path) "(configure! (coder-config {:model \"m1\"}))")
  (reload-config!)
  (check "model applied"     (:model *config*) "m1")
  (check-true "no error"     (not *config-error*))
  (file/write (config-path) "(broken")
  (reload-config!)
  (check-true "error set"    *config-error*)
  (check "last-good kept"    (:model *config*) "m1"))

(done)
