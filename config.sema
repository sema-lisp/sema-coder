;; config.sema — configuration as DATA.
;;
;; init.sema is Lisp that calls value-returning constructors (coder-config,
;; mcp-server, command) and hands the result to (configure! cfg). The loader is
;; pure: it captures that value and returns {:ok cfg} | {:error e} — it never
;; mutates the app's active config or prints, so the caller owns recovery policy
;; and reconciles runtime to the returned value (no accumulators, no reset).

(load "util.sema")

;; A parameter so tests (and a future --config flag) can redirect the dir.
(define config-dir-override (make-parameter #f))
(defun config-dir ()
  (or (config-dir-override)
      (let ((e (env "SEMA_CODER_CONFIG_DIR"))) (if (and e (not (= e ""))) e #f))
      (path/join (sys/config-dir) "sema" "sema-code")))
(defun config-path () (path/join (config-dir) "init.sema"))

(define default-config
  {:model          ""        ;; "" = auto-detect from API keys
   :max-turns      50
   :context-budget 80000
   :mcp-servers    '()
   :commands       '()})

;; ── Constructors: return values, never mutate ────────────────────

(defun mcp-server (name opts)
  "A server record. OPTS is the mcp/connect map plus the app key :autostart."
  {:name      name
   :opts      (dissoc opts :autostart)
   :autostart (get opts :autostart #f)
   :transport (if (get opts :url #f) "http" "stdio")})

(defun command (name spec)
  "A command record. SPEC carries :desc and one of :run (argv) / :do (fn) / :shell."
  (assoc spec :name name))

(defun coder-config (m)
  "Assemble the config value, filling any omitted key from the defaults."
  (merge default-config m))

;; ── Single sink + pure loader ────────────────────────────────────
;; configure! writes a scratch cell, not the active config, so a load that
;; throws mid-file can't leave the app's config half-applied.

(define *pending-config* #f)

(defun configure! (cfg) (set! *pending-config* cfg) cfg)

(defun load-config (path)
  "Read + evaluate PATH, capture the configured value. Pure: {:ok cfg} | {:error e}."
  (set! *pending-config* #f)
  (try
    (begin
      (load path)
      (if *pending-config*
        {:ok *pending-config*}
        {:error "init.sema did not call (configure! …)"}))
    (catch e {:error e})))

;; ── First-run default (annotated so humans + agents copy correct syntax) ──

(define default-init-source
";; init.sema — Sema Coder config (Lisp data, hot-reloaded on save).
;; Edit in any editor; declarations are values the app reconciles to.

(configure!
  (coder-config
    {:model      \"\"                 ; \"\" = auto-detect from API keys; or \"claude-sonnet-5\"
     :max-turns  50

     ;; ── MCP servers — manage in the /mcp modal (⌃O). Each is a value. ──
     :mcp-servers
     (list
       ;; Sema's own MCP server: gives the agent eval + docs into Sema itself.
       ;; On by default — comment out this line to disable it.
       (mcp-server \"sema\" {:command \"sema\" :args [\"mcp\" \"--include\" \"eval,docs,docs_search\"]
                           :autostart #t})
       ;; (mcp-server \"fs\"    {:command \"npx\" :args [\"-y\" \"@modelcontextprotocol/server-filesystem\" \".\"]})
       ;; (mcp-server \"asana\" {:url \"https://mcp.asana.com/mcp\"})   ; OAuth when you connect
       )   ; only add servers you trust — they run real commands / reach real services

     ;; ── Slash commands — argv (no shell), or a Lisp handler. ──
     :commands
     (list
       (command \"test\" {:desc \"run tests\" :run [\"make\" \"test\"]})
       ;; (command \"log\" {:desc \"git log\" :run [\"git\" \"log\" \"--oneline\" \"-n\" :args]})
       )}))
")

(defun ensure-config! ()
  "Write the annotated default init.sema if none exists. Returns the path."
  (let ((path (config-path)))
    (unless (file/exists? path)
      (file/mkdir (config-dir))
      (file/write path default-init-source))
    path))
